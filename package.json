{
  "name": "blog-api",
  "version": "1.0.0",
  "description": "REST API for a blog application with real-time comments",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "test": "jest --forceExit --coverage",
    "test:watch": "jest --watch",
    "snyk:test": "snyk test",
    "snyk:monitor": "snyk monitor"
  },
  "author": "OrtegaGhost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OrtegaGhost/blog-api.git"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "testTimeout": 10000,
    "forceExit": true
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "snyk": "^1.1305.1",
    "supertest": "^7.2.2"
  }
}
